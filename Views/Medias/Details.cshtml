@model Models.Media
@{
    ViewBag.PageTitle = "Détails";
}

<div id="detailsPanel" class="detailsPanel">
    <!-- auto refreshed -->
</div>

@section Scripts {
    <script>
        $(() => {
            newSession(600);
            mediaDetails_ARP = new AutoRefreshedPanel("detailsPanel", "/Medias/GetMediaDetails", 5, mediaDetailsPostRefresh);
        })
        
        function mediaDetailsPostRefresh() {
            let accessDenied = $("#detailsPanel").find(".fa-exclamation-triangle").length > 0;

            if (accessDenied) {
                $(".fa-edit, .fa-trash, .fa-trash-can, .fa-pen-to-square, .fa-thumbs-up").hide();

                $('a[href*="/Medias/Edit"]').remove();
                $('a[href*="/Medias/Delete"]').remove();
            }
        }
     </script>
}